# PostgreSQL and Docker Compose
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=
POSTGRES_DB=agentflow
POSTGRES_PORT=5432
BACKEND_PORT=8000
DATABASE_URL=

# Anthropic integration
ANTHROPIC_ENABLED=false
AGENT_DYNAMIC_PLANNING_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_MAX_RETRIES=2

# Independent dynamic-agent cost controls
# Blank model values fall back to ANTHROPIC_MODEL.
AGENT_DYNAMIC_PLANNER_MODEL=
AGENT_DYNAMIC_PLANNER_MAX_TOKENS=1024
AGENT_DYNAMIC_SYNTHESIS_MODEL=
AGENT_DYNAMIC_SYNTHESIS_MAX_TOKENS=2048

# Pricing is configuration-driven to avoid stale vendor rates.
AGENT_DYNAMIC_PLANNER_INPUT_COST_PER_MILLION_USD=0
AGENT_DYNAMIC_PLANNER_OUTPUT_COST_PER_MILLION_USD=0
AGENT_DYNAMIC_SYNTHESIS_INPUT_COST_PER_MILLION_USD=0
AGENT_DYNAMIC_SYNTHESIS_OUTPUT_COST_PER_MILLION_USD=0
# Leave blank to disable the fail-closed per-request ceiling.
AGENT_DYNAMIC_MAX_ESTIMATED_COST_USD=
